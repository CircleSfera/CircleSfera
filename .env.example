# Root / shared example env for local tooling (Playwright, compose overrides).
# Copy to .env and fill real values. Never commit real .env files.

# Playwright e2e (required for `npm run test:e2e`)
E2E_USER_EMAIL=e2e@example.com
E2E_USER_PASSWORD=change-me-strong-password
E2E_USER_USERNAME=e2euser
E2E_USER_FULL_NAME=E2E Test User
BASE_URL=http://localhost:5173
BACKEND_URL=http://localhost:3005/api/v1

# Production Redis (required by docker-compose.prod.yml)
REDIS_PASSWORD=change-me-strong-redis-password

# Live streaming (LiveKit Cloud or self-hosted). Required in production.
# Backend reads KEY/SECRET from .env.production at runtime.
# Frontend bakes LIVEKIT_URL (or VITE_LIVEKIT_URL) into the image at CI build time.
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://your-project.livekit.cloud

# Optional: Docker frontend Vite proxy target (set automatically in compose)
# VITE_API_PROXY_TARGET=http://backend:3000

# GitHub E2E secrets setup (after `gh auth login`):
#   ./scripts/setup-github-e2e.sh
