#!/bin/sh


# Pre-commit hook to prevent secret leaks

echo "🛡️ CircleSfera Security: Scanning for secrets..."

# 1. Prevent .env files from being committed entirely
STAGED_ENV_FILES=$(git diff --cached --name-only | grep -E '^\.env$|\.env\.')

if [ -n "$STAGED_ENV_FILES" ]; then
  # .env.example is usually fine, but let's exclude it from the error if it's strictly .env.example
  for file in $STAGED_ENV_FILES; do
    if [ "$file" != ".env.example" ]; then
      echo "❌ ERROR: You are trying to commit a sensitive environment file: $file"
      echo "Please run: git reset HEAD $file"
      echo "And ensure it is in your .gitignore file."
      exit 1
    fi
  done
fi

# 2. Simple regex scan for hardcoded secrets in staged changes
# Skips .env.example
git diff --cached -G"(sk-[a-zA-Z0-9]{32,}|xkeysib-[a-zA-Z0-9]{50,})" --name-only | while read file; do
    if [ "$file" != ".env.example" ]; then
        echo "❌ ERROR: Possible secret leak detected in file: $file"
        echo "Please remove hardcoded secrets (API keys, etc.) before committing."
        exit 1
    fi
done

echo "✅ Security scan passed."
